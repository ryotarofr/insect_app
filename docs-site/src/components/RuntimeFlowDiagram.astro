---
// RuntimeFlowDiagram.astro — 1 リクエストの中でブランド型がどう変身していくかを示す図
//
// **使い方** (MDX 内):
//   import RuntimeFlowDiagram from "../../../components/RuntimeFlowDiagram.astro";
//   <RuntimeFlowDiagram />
---

<svg
  viewBox="0 0 980 480"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-labelledby="runtime-flow-title runtime-flow-desc"
  style="width: 100%; height: auto; max-width: 980px; display: block;"
>
  <title id="runtime-flow-title">Brand lifecycle on a single request</title>
  <desc id="runtime-flow-desc">
    Sequence with high-contrast colors: handler builds Href via parse(), serde transparent emits string,
    fetch returns branded type, consumer uses href as Href.
  </desc>

  <rect x="0" y="0" width="980" height="480" fill="#faf8f3" />

  <defs>
    <marker id="runtime-flow-arr" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="9" markerHeight="9" orient="auto">
      <path d="M0,0 L10,5 L0,10 z" fill="#475569" />
    </marker>
  </defs>

  <text x="20" y="28" font-family="system-ui, sans-serif" font-size="15" font-weight="700" fill="#0f172a">
    1 リクエストのライフサイクル (Href が変身していく順)
  </text>

  <!-- swimlane label bands -->
  <rect x="20" y="48" width="100" height="100" fill="#1e293b" rx="6" />
  <text x="70" y="92"  text-anchor="middle" font-family="system-ui, sans-serif" font-size="13" font-weight="700" fill="#ffffff">Rust</text>
  <text x="70" y="110" text-anchor="middle" font-family="ui-monospace, monospace" font-size="10.5" fill="#cbd5e1">handler</text>

  <rect x="20" y="153" width="100" height="80" fill="#475569" rx="6" />
  <text x="70" y="187" text-anchor="middle" font-family="system-ui, sans-serif" font-size="13" font-weight="700" fill="#ffffff">JSON</text>
  <text x="70" y="205" text-anchor="middle" font-family="ui-monospace, monospace" font-size="10.5" fill="#e2e8f0">wire</text>

  <rect x="20" y="238" width="100" height="100" fill="#15803d" rx="6" />
  <text x="70" y="282" text-anchor="middle" font-family="system-ui, sans-serif" font-size="13" font-weight="700" fill="#ffffff">TS</text>
  <text x="70" y="300" text-anchor="middle" font-family="ui-monospace, monospace" font-size="10.5" fill="#dcfce7">api / view</text>

  <rect x="20" y="343" width="100" height="120" fill="#92400e" rx="6" />
  <text x="70" y="395" text-anchor="middle" font-family="system-ui, sans-serif" font-size="13" font-weight="700" fill="#ffffff">Type</text>
  <text x="70" y="413" text-anchor="middle" font-family="ui-monospace, monospace" font-size="10.5" fill="#fef3c7">at boundary</text>

  <!-- swimlane background bands -->
  <rect x="125" y="48"  width="835" height="100" fill="#ffffff" stroke="#cbd5e1" stroke-width="1" rx="4" />
  <rect x="125" y="153" width="835" height="80"  fill="#ffffff" stroke="#cbd5e1" stroke-width="1" rx="4" />
  <rect x="125" y="238" width="835" height="100" fill="#ffffff" stroke="#cbd5e1" stroke-width="1" rx="4" />
  <rect x="125" y="343" width="835" height="120" fill="#ffffff" stroke="#cbd5e1" stroke-width="1" rx="4" />

  <!-- step 1 (Rust) -->
  <rect x="160" y="62" width="200" height="76" fill="#fef9c3" stroke="#15803d" stroke-width="1.8" rx="6" />
  <circle cx="178" cy="80" r="11" fill="#15803d" />
  <text x="178" y="85"  text-anchor="middle" font-family="system-ui, sans-serif" font-size="12" font-weight="700" fill="#ffffff">1</text>
  <text x="196" y="84"  font-family="system-ui, sans-serif" font-size="12" font-weight="700" fill="#0f172a">Href::parse(...)</text>
  <text x="178" y="106" font-family="ui-monospace, monospace" font-size="10.5" fill="#0f172a">→ Ok(Href("/products/p-1"))</text>
  <text x="178" y="124" font-family="system-ui, sans-serif" font-size="10.5" fill="#475569">不正なら HrefError で 4xx</text>

  <!-- step 2 (JSON) -->
  <rect x="395" y="166" width="200" height="56" fill="#f1f5f9" stroke="#475569" stroke-width="1.2" rx="6" />
  <circle cx="413" cy="184" r="11" fill="#475569" />
  <text x="413" y="189" text-anchor="middle" font-family="system-ui, sans-serif" font-size="12" font-weight="700" fill="#ffffff">2</text>
  <text x="431" y="188" font-family="system-ui, sans-serif" font-size="12" font-weight="700" fill="#0f172a">serde_json (transparent)</text>
  <text x="413" y="210" font-family="ui-monospace, monospace" font-size="11" fill="#0f172a">"/products/p-1"</text>

  <!-- step 3 (TS api) -->
  <rect x="500" y="252" width="200" height="76" fill="#f1f5f9" stroke="#475569" stroke-width="1.2" rx="6" />
  <circle cx="518" cy="270" r="11" fill="#475569" />
  <text x="518" y="275" text-anchor="middle" font-family="system-ui, sans-serif" font-size="12" font-weight="700" fill="#ffffff">3</text>
  <text x="536" y="274" font-family="system-ui, sans-serif" font-size="12" font-weight="700" fill="#0f172a">fetchJson&lt;CardBlock&gt;()</text>
  <text x="518" y="296" font-family="ui-monospace, monospace" font-size="10.5" fill="#0f172a">await res.json()</text>
  <text x="518" y="314" font-family="system-ui, sans-serif" font-size="10.5" fill="#475569">return as CardBlock (branded)</text>

  <!-- step 4 (consumer) -->
  <rect x="730" y="252" width="200" height="76" fill="#fef9c3" stroke="#15803d" stroke-width="1.8" rx="6" />
  <circle cx="748" cy="270" r="11" fill="#15803d" />
  <text x="748" y="275" text-anchor="middle" font-family="system-ui, sans-serif" font-size="12" font-weight="700" fill="#ffffff">4</text>
  <text x="766" y="274" font-family="system-ui, sans-serif" font-size="12" font-weight="700" fill="#0f172a">CtaBlockView (Cta.tsx)</text>
  <text x="748" y="296" font-family="ui-monospace, monospace" font-size="10.5" fill="#0f172a">&lt;a href={`{block.href}`}&gt;</text>
  <text x="748" y="314" font-family="system-ui, sans-serif" font-size="10.5" fill="#15803d" font-weight="700">block.href : Href ✓ 型 OK</text>

  <!-- arrows -->
  <line x1="260" y1="138" x2="490" y2="166" stroke="#475569" stroke-width="1.5" marker-end="url(#runtime-flow-arr)" />
  <text x="280" y="156" font-family="system-ui, sans-serif" font-size="10.5" fill="#334155" font-weight="600">.to_json()</text>

  <line x1="490" y1="222" x2="600" y2="252" stroke="#475569" stroke-width="1.5" marker-end="url(#runtime-flow-arr)" />
  <text x="500" y="244" font-family="system-ui, sans-serif" font-size="10.5" fill="#334155" font-weight="600">HTTP 200 OK</text>

  <line x1="700" y1="290" x2="730" y2="290" stroke="#475569" stroke-width="1.5" marker-end="url(#runtime-flow-arr)" />
  <text x="700" y="280" font-family="system-ui, sans-serif" font-size="10.5" fill="#334155" font-weight="600">prop で渡す</text>

  <!-- type evolution lane -->
  <rect x="160" y="362" width="180" height="60" fill="#fff7ed" stroke="#92400e" stroke-width="1.2" rx="6" />
  <text x="250" y="384" text-anchor="middle" font-family="system-ui, sans-serif" font-size="12" font-weight="700" fill="#0f172a">Href (Rust newtype)</text>
  <text x="250" y="403" text-anchor="middle" font-family="system-ui, sans-serif" font-size="10.5" fill="#475569">String + parse 検証付き</text>

  <rect x="380" y="362" width="180" height="60" fill="#fff7ed" stroke="#92400e" stroke-width="1.2" rx="6" />
  <text x="470" y="384" text-anchor="middle" font-family="system-ui, sans-serif" font-size="12" font-weight="700" fill="#0f172a">string</text>
  <text x="470" y="403" text-anchor="middle" font-family="system-ui, sans-serif" font-size="10.5" fill="#475569">brand は wire に乗らない</text>

  <rect x="600" y="362" width="180" height="60" fill="#fff7ed" stroke="#92400e" stroke-width="1.2" rx="6" />
  <text x="690" y="384" text-anchor="middle" font-family="system-ui, sans-serif" font-size="12" font-weight="700" fill="#0f172a">G.Href = string</text>
  <text x="690" y="403" text-anchor="middle" font-family="system-ui, sans-serif" font-size="10.5" fill="#475569">ts-rs 自動生成 (素の string)</text>

  <rect x="760" y="362" width="180" height="60" fill="#fef9c3" stroke="#15803d" stroke-width="1.8" rx="6" />
  <text x="850" y="384" text-anchor="middle" font-family="system-ui, sans-serif" font-size="12" font-weight="700" fill="#0f172a">Href (branded)</text>
  <text x="850" y="403" text-anchor="middle" font-family="system-ui, sans-serif" font-size="10.5" fill="#15803d" font-weight="700">overlay 適用後</text>

  <line x1="340" y1="392" x2="378" y2="392" stroke="#475569" stroke-width="1.5" marker-end="url(#runtime-flow-arr)" />
  <line x1="560" y1="392" x2="598" y2="392" stroke="#475569" stroke-width="1.5" marker-end="url(#runtime-flow-arr)" />
  <line x1="780" y1="392" x2="758" y2="392" stroke="#15803d" stroke-width="2" marker-end="url(#runtime-flow-arr)" />

  <text x="160" y="450" font-family="system-ui, sans-serif" font-size="11.5" fill="#92400e" font-weight="700">
    ★ ステップ 4 で生 string を渡そうとすると tsc コンパイル時にエラー ── これがブランドの「効き」。
  </text>
</svg>

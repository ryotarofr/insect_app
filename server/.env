# server/.env.example — 開発用環境変数のテンプレート
#
# 使い方:
#   cp server/.env.example server/.env
#   # 必要に応じて値を書き換える
#   # cargo run / cargo test は dotenvy 経由で自動的に読み込む。
#
# **本番では .env ファイルを使わず、AWS Secrets Manager / Parameter Store からロードする。
#   コミットするのは .env.example のみ (= .env は .gitignore 対象)。**

# ── PostgreSQL ──────────────────────────────────────────────────
# docker-compose.yml で立ち上げる kochu_postgres_dev に対応する DSN。
# host (5432) ↔ container (5432) で 1:1 でマップしているのでこのまま使える。
DATABASE_URL=postgresql://kochu:kochu_dev_password@localhost:5432/kochu_dev

# Connection pool の最大コネクション数。dev では 5 もあれば十分。
DB_MAX_CONNECTIONS=5

# 起動時に sqlx::migrate! を実行するか (true/false)。
# dev では true 推奨。production では一度きりの migration job で別途回す想定なので false。
DB_AUTO_MIGRATE=true

# ── Server ──────────────────────────────────────────────────────
# axum がバインドするアドレス + ポート。
KOCHU_BIND_ADDR=0.0.0.0:3000

# tracing log filter。本番は `info`、dev は `debug` を推奨。
RUST_LOG=insect_app=debug,tower_http=debug,axum=debug,sqlx=warn

# ── Stripe (Phase 9 で使用、現状未使用) ─────────────────────────
# Stripe を実装するまでは未設定で良い (= mock provider が動く前提)。
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PROVIDER=mock   # mock | live

# ── Analytics ring buffer (任意) ───────────────────────────────
# in-memory ring buffer の容量。env override が要らなければ未設定で OK。
# KOCHU_ANALYTICS_RING_CAP=1000
